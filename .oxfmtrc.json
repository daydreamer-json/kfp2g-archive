{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "output/raw/**/ab_list.json",
    "output/raw/**/ab_list.txt",
    "output/raw/**/ab_guid.txt",
    "output/raw/**/filesize.csv",
    "output/parade/common/mst_data/all.json",
    "output/parade/common/mst_data/latest.json",
    "output/parade/common/mst_data_raw_latest/*.json"
  ],
  "useTabs": false,
  "printWidth": 120,
  "tabWidth": 2,
  "endOfLine": "lf",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "css",
  "insertFinalNewline": true,
  "jsxSingleQuote": true,
  "objectWrap": "preserve",
  "proseWrap": "preserve",
  "quoteProps": "as-needed",
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all"
}
